   private serializeProperty(property: any) {
  return {
    ...property,

    price:
      property.price != null
        ? Number(property.price)
        : null,

    securityDeposit:
      property.securityDeposit != null
        ? Number(property.securityDeposit)
        : null,

    latitude:
