  IsOptional,
  IsString,
  Min,
} from 'class-validator';


export enum SortOrder {
  ASC = 'asc',
  DESC = 'desc',
}


export class FilterPropertiesDto {


  @ApiPropertyOptional({
    description: 'Search title, city, locality',
    example: 'Luxury Apartment',
  })
  @IsOptional()
  @IsString()
  search?: string;



  @ApiPropertyOptional({
    example: 'Bangalore',
  })
  @IsOptional()
  @IsString()
  city?: string;



  @ApiPropertyOptional({
    example: 'HSR Layout',
