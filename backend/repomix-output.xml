import { Injectable } from '@nestjs/common';

@Injectable()
export class HealthService {
  getHealth() {
    return {
      status: 'ok',
      service: 'RentEase Backend',
      version: '1.0.0',
      environment:
        process.env.NODE_ENV || 'development',
      timestamp: new Date().toISOString(),
