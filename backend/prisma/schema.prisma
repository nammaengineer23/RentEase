generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(uuid())
  fullName      String
  email         String          @unique
  phone         String          @unique
  role          UserRole        @default(USER)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  passwordHash  String
  favorites     Favorite[]
  notifications Notification[]
  properties    Property[]
  visits        PropertyVisit[] @relation("TenantVisits")
  refreshTokens RefreshToken[]
  reviews       Review[]
}

model Property {
  id              String            @id @default(cuid())
  title           String
  description     String
  price           Decimal           @db.Decimal(10, 2)
  address         String
  city            String
  state           String
  country         String
  pincode         String
  bedrooms        Int
  bathrooms       Int
  area            Float
  propertyType    PropertyType
  furnishing      FurnishingType
  parking         Boolean           @default(false)
  petFriendly     Boolean           @default(false)
  securityDeposit Decimal           @db.Decimal(10, 2)
  isAvailable     Boolean           @default(true)
  ownerId         String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  landmark        String?
  latitude        Float?
  locality        String?
  longitude       Float?
  displayOrder    Int               @default(0)
  favorites       Favorite[]
  owner           User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  amenities       PropertyAmenity[]
  images          PropertyImage[]
  visits          PropertyVisit[]
  reviews         Review[]
}

model Amenity {
  id         String            @id @default(cuid())
  name       String            @unique
  createdAt  DateTime          @default(now())
  properties PropertyAmenity[]
}

model PropertyAmenity {
  propertyId String
  amenityId  String
  amenity    Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([propertyId, amenityId])
}

model PropertyImage {
  id           String   @id @default(cuid())
  imageUrl     String
  publicId     String?
  isPrimary    Boolean  @default(false)
  displayOrder Int      @default(0)
  propertyId   String
  createdAt    DateTime @default(now())
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
}

model Review {
  id         String   @id @default(cuid())
  rating     Int
  comment    String?
  userId     String
  propertyId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([propertyId])
}

model PropertyVisit {
  id         String      @id @default(cuid())
  propertyId String
  tenantId   String
  visitDate  DateTime
  status     VisitStatus @default(PENDING)
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  property   Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant     User        @relation("TenantVisits", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([tenantId])
  @@index([visitDate])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  expiresAt DateTime
  userId    String
  createdAt DateTime @default(now())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  USER
  OWNER
  ADMIN
}

enum PropertyType {
  APARTMENT
  HOUSE
  VILLA
  STUDIO
  ROOM
  PG
}

enum FurnishingType {
  UNFURNISHED
  SEMI_FURNISHED
  FULLY_FURNISHED
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
  RENTED
}

enum VisitStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}
